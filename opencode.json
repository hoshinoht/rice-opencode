{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "opencode-anthropic-auth@latest",
    "@mohak34/opencode-notifier@latest"
  ],
  "agent": {
    "plan": {
      "description": "Strategic planning agent. Analyzes requirements and creates implementation plans.",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-5",
      "variant": "max",
      "temperature": 1.0,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "websearch": true,
        "webfetch": true,
        "search_research_articles": true,
        "search_research_articles_advanced": true,
        "get_researcher_info": true
      }
    },
    "build": {
      "description": "Primary builder agent. Executes implementation with best practices.",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-5",
      "variant": "max",
      "prompt": "{file:prompts/builder-prompt.md}",
      "temperature": 1.0
    },
    "explore": {
      "description": "Fast file system navigator. Locates files, logs, configs, or code relevant to tasks.",
      "mode": "subagent",
      "model": "kimi-for-coding/k2p5",
      "variant": "max",
      "prompt": "{file:agents/explore.md}",
      "temperature": 1.0,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "write": false,
        "edit": false
      }
    },
    "docs-first-coder": {
      "description": "Documentation-first coding expert. Verifies APIs against current docs before implementation.",
      "mode": "subagent",
      "model": "kimi-for-coding/k2p5",
      "variant": "max",
      "prompt": "{file:agents/docs-first-coder.md}",
      "temperature": 1.0,
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "webfetch": true,
        "websearch": true,
        "search_research_articles": true,
        "search_research_articles_advanced": true,
        "get_researcher_info": true
      }
    },
    "code-checker": {
      "description": "Code verification specialist. Three-pillar analysis: smells, spec alignment, correctness.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "variant": "max",
      "prompt": "{file:agents/code-checker.md}",
      "temperature": 1.0,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "webfetch": true,
        "websearch": true,
        "write": false,
        "edit": false
      }
    },
    "esp32-tdd-coder": {
      "description": "ESP32 embedded systems coder following TDD principles. Refuses code without tests unless overridden.",
      "mode": "subagent",
      "model": "kimi-for-coding/k2p5",
      "variant": "max",
      "prompt": "{file:agents/esp32-tdd-coder.md}",
      "temperature": 1.0,
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "webfetch": true,
        "websearch": true
      }
    },
    "esp32-tdd-test-writer": {
      "description": "ESP32 TDD test writer. Generates unit tests from technical design docs. Rejects sparse docs.",
      "mode": "subagent",
      "model": "kimi-for-coding/k2p5",
      "variant": "max",
      "prompt": "{file:agents/esp32-tdd-test-writer.md}",
      "temperature": 1.0,
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "webfetch": true,
        "websearch": true
      }
    },
    "document-writer": {
      "description": "Creates professional documents, academic papers, and reports using pandoc.",
      "mode": "subagent",
      "model": "kimi-for-coding/k2p5",
      "variant": "max",
      "prompt": "{file:agents/document-writer.md}",
      "temperature": 1.0,
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "docs_convert": true,
        "docs_compile_latex": true,
        "docs_presets_list": true,
        "docs_presets_show": true,
        "docs_templates_list": true,
        "docs_templates_install": true,
        "docs_create": true,
        "docs_create_ieee_paper": true,
        "docs_create_school_report": true,
        "docs_create_styled_pdf": true,
        "webfetch": false,
        "websearch": false,
        "search_research_articles": true,
        "search_research_articles_advanced": true,
        "get_researcher_info": true
      }
    }
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      },
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-brave-search"],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "enabled": true
    },
    "ddg-search": {
      "type": "local",
      "command": ["npx", "-y", "@oevortex/ddg_search@latest"],
      "enabled": true
    },
    "researcher-mcp": {
      "type": "local",
      "command": [
        "./researcher-mcp/bin/google-scholar-mcp"
      ],
      "enabled": true
    }
  }
}
